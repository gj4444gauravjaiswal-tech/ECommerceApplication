@{
    Layout = "_Layout2";
}

<!-- Banner Section -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="p-4 bg-success text-white rounded-3">
            <h4>Fresh Fruits</h4>
            <p>Get fresh fruits delivered in 15 minutes</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="p-4 bg-warning text-dark rounded-3">
            <h4>Snacks & Drinks</h4>
            <p>All your favorite snacks available</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="p-4 bg-info text-white rounded-3">
            <h4>Baby Care</h4>
            <p>Everything for your baby</p>
        </div>
    </div>
</div>

<!-- Categories -->
<h4 class="mb-3">Products Category</h4>
<div class="row mb-4" id="productcategory">

</div>

<!-- Product Section -->
<h4 class="mb-3">Popular Products</h4>

<div class="row" id="popularproducts">

</div>

<script src="~/lib/jquery/dist/jquery.js"></script>
<script>
    $(document).ready(function(){
        ShowAllCategory();
        ShowAllProducts();
    })
    function ShowAllCategory(){
        $.ajax({
            url:'/api/APIUser/GetAllCategory',
            type:'GET',
            success:function(Category){
                if(Category != null){
                    var catdata = "";
                    $.each(Category,function(i,cat){
                        catdata += `<div class="col-md-2">
                                        <div class="category-card shadow-sm">
                                        <img src="/images/${cat.c_Pic}" height="100px" width="100%"/>
                                        <p class="fw-bold">${cat.c_Name}</p>
                                        </div>
                                    </div>`
                    })
                    $("#productcategory").html(catdata);
                }
            },
            error:function(err){
                if(err){
                    Swal.fire('Error!','Server Error Cannot Load Category','Error')
                }
            }
        })
    }
    function ShowAllProducts(){
        $.ajax({
            url:'/api/APIUser/GetAllProduct',
            type:'GET',
            success: function(Products){
                if(Products != null){
                    var Prods = "";
                    $.each(Products,function(i,proitem){
                        Prods += `<div class="col-md-3 mb-4 product-item" data-name="${proitem.p_Name}">
                                    <div class="card product-card p-3">
                                        <img src="/images/${proitem.p_Pic}" class="card-img-top" height="160px">
                                        <div class="card-body">
                                            <h6>${proitem.p_Name}</h6>
                                            <p>₹${proitem.p_Price}</p>
                                            <button class="btn btn-success w-100">Add to Cart</button>
                                        </div>
                                    </div>
                                </div>`
                    })
                    $("#popularproducts").html(Prods);
                }
                else{
                    Swal.fire('Error!','No Products Found','Error')
                }
            },
            error: function(err){
                if(err != null){
                    Swal.fire('Error!','Server Error Cannot Load Products','Error')
                }
            }
        })
    }
</script>