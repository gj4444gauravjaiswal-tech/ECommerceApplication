<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/fontawesome.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/solid.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/brands.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body {
            overflow-x: hidden;
            background: linear-gradient(135deg,#fff5f5,#ffeaea);
            font-family: 'Segoe UI', sans-serif;
        }

        /* TOP NAVBAR */
        .navbar {
            background: linear-gradient(90deg,#8b0000,#e52d27) !important;
        }

        .navbar-brand {
            color: white !important;
            font-size: 22px;
            letter-spacing: 1px;
        }

        /* SIDEBAR */
        .sidebar {
            height: 100vh;
            background: linear-gradient(180deg,#8b0000,#c82333);
            box-shadow: 5px 0 20px rgba(0,0,0,0.1);
        }

            .sidebar h5 {
                font-weight: bold;
                letter-spacing: 1px;
            }

            .sidebar a {
                color: #ffeaea;
                text-decoration: none;
                padding: 10px 15px;
                border-radius: 10px;
                transition: 0.3s;
                display: block;
            }

                .sidebar a:hover {
                    background: rgba(255,255,255,0.15);
                    color: #fff;
                    padding-left: 20px;
                }

            .sidebar .nav-link.active {
                background: white;
                color: #c82333 !important;
                font-weight: bold;
            }

        /* MAIN CONTENT */
        .main-content {
            padding: 25px;
        }

        /* STAT CARDS */
        .stat-card {
            color: white;
            border-radius: 15px;
            padding: 25px;
            transition: 0.3s;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        }

            .stat-card:hover {
                transform: translateY(-5px);
            }

        .bg-blue {
            background: linear-gradient(45deg,#8b0000,#e52d27);
        }

        .bg-green {
            background: linear-gradient(45deg,#b31217,#ff4b2b);
        }

        .bg-yellow {
            background: linear-gradient(45deg,#c82333,#ff6b6b);
        }

        .bg-red {
            background: linear-gradient(45deg,#7b0000,#b71c1c);
        }

        /* TABLE */
        .table thead {
            background: #c82333;
            color: white;
        }

        /* LOGOUT BUTTON */
        .btn-danger {
            background: linear-gradient(90deg,#8b0000,#e52d27);
            border: none;
            border-radius: 25px;
            transition: 0.3s;
        }

            .btn-danger:hover {
                transform: scale(1.05);
                box-shadow: 0 10px 20px rgba(109,50,39,0.6);
            }

    </style>
</head>
<body>

    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-lg shadow-sm px-4">
        <span class="navbar-brand fw-bold">
            <i class="fa fa-store me-2"></i> ECommerce Store
        </span>
    </nav>

    <div class="container-fluid">
        <div class="row">

            <!-- Sidebar -->
            <div class="col-md-2 sidebar p-3">
                <ul class="nav flex-column">

                    <li class="nav-item mb-2">
                        <a class="nav-link active" href="/Admin/Dashboard">
                            <i class="fa fa-home me-2"></i> Dashboard
                        </a>
                    </li>

                    <li class="nav-item mb-2">
                        <a class="nav-link" href="/Admin/AddCategory">
                            <i class="fa fa-list me-2"></i> Categories
                        </a>
                    </li>

                    <li class="nav-item mb-2">
                        <a class="nav-link" href="/Admin/AddProduct">
                            <i class="fa fa-box me-2"></i> Products
                        </a>
                    </li>

                    <li class="nav-item mb-2">
                        <a class="nav-link" href="/Admin/MyProfile">
                            <i class="fa fa-box me-2"></i> My Profile
                        </a>
                    </li>

                    <li class="nav-item mt-4">
                        <a class="btn btn-danger w-100" href="/Admin/Logout">
                            <i class="fa fa-sign-out-alt me-2"></i> Logout
                        </a>
                    </li>

                </ul>
            </div>

            <!-- Main Content -->
            <div class="col-md-10 main-content">

                @RenderBody()

            </div>
        </div>
    </div>

</body>
</html>