@{
    Layout = "_Layout1";
}
<div class="row mb-4">
    <h1 class="text-center text-danger">Welcome To Admin Dashboard</h1>
</div>
<!-- Statistic Cards -->
<div class="row mb-4">
    <div class="col-md-3 mt-2">
        <a href="/admin/managecategory" id="totalcategory" class="nav-link">

        </a>
    </div>
    <div class="col-md-3 mt-2">
        <a href="/admin/manageproduct" id="totalproducts" class="nav-link">

        </a>
    </div>
    <div class="col-md-3 mt-2">
        <a href="/admin/manageuser" id="totalusers" class="nav-link">

        </a>
    </div>
    <div class="col-md-3 mt-2">
        <a href="#" class="nav-link">
            <div class="stat-card bg-red">
                <h3>6</h3>
                <p>Total Orders</p>
            </div>
        </a>
    </div>
</div>
<div class="row">
    <div class="col-md-4">
        <div class="card shadow rounded-3 p-3">
            <h5 class="text-center mb-3">Sales Progress</h5>
            <div style="height:300px;">
                <canvas id="barChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow rounded-3 p-3">
            <h5 class="text-center mb-3">Business Report</h5>
            <div style="height:300px;">
                <canvas id="doughnutChart" height="120"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow rounded-3 p-3">
            <h5 class="text-center mb-3">Business Analaysis</h5>
            <div style="height:300px;">
                <canvas id="polarChart" height="120"></canvas>
            </div>
        </div>
    </div>
</div>
<script src="~/lib/jquery/dist/jquery.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
<script>
    $(document).ready(function(){
       GetCount(); 
       Charts();
       createDoughnutChart();
       createPolarChart();
    });
        function GetCount(){
        $.ajax({
            url:'/api/APIAdmin/GetAllCategory',
            type:'GET',
            success:function(result){
                if(result != null){

                    var count = result.length;   // ✅ yaha count milega

                    $("#totalcategory").append(`<div class="stat-card bg-blue"><h3>${count}</h3><p>Total Categories</p></div>`);  // show in HTML
                    CountNum();
                }
            }
        })
        $.ajax({
            url:'/api/APIAdmin/GetAllProduct',
            type:'GET',
            success:function(result){
                if(result != null){

                    var count = result.length;   // ✅ yaha count milega

                    $("#totalproducts").append(`<div class="stat-card bg-green"><h3>${count}</h3><p>Total Products</p></div>`);  // show in HTML
                    CountNum();
                }
            }
        })
        $.ajax({
            url:'/api/APIAdmin/GetAllUser',
            type:'GET',
            success:function(result){
                if(result != null){
                    console.log(result);
                    var count = result.length;   // ✅ yaha count milega
                    $("#totalusers").append(`<div class="stat-card bg-yellow text-dark"><h3>${count}</h3><p>Total Registrations</p></div>`);  // show in HTML
                    GetUserTable();
                }
            }
        })
    }
    function CountNum(){
        $('.stat-card').each(function(){
            var value = parseInt($(this).find('h3').text());
            var count = 0;
            var interval = setInterval(() => {
                if(count < value){
                    count++;
                    $(this).find('h3').text(count);
                } else {
                    clearInterval(interval);
                }
            }, 100);
        });
    }
    function GetUserTable(){
        $('#userTable').DataTable({

        ajax: {
            url: '/api/APIAdmin/GetAllUser',
            type: 'GET',
            dataSrc: ''
        },

        columns: [
            { data: 'id' },
            { data: 'name' },
            { data: 'email' },

            // ⚠ Password dikhana secure nahi hota
            { data: 'password' },

            { data: 'mobile' },
            { data: 'address' },
            {
                data: 'id',
                render: function (data) {
                    return `
                        <button class="btn btn-outline-warning btn-sm" onclick="Edit(${data})">Edit</button>
                        <button class="btn btn-outline-danger btn-sm" onclick="Delete(${data})">Delete</button>
                    `;
                }
            }
        ],

        pageLength: 5,
        lengthMenu: [5, 10, 25, 50],
        ordering: true,
        searching: true,
        responsive: true,
        autoWidth: false
    });
    }
    let barChartInstance = null;
    let doughnutChartInstance = null;
    let polarChartInstance = null;

    function Charts() {

        $.ajax({
            url: '/api/APIAdmin/DashboardCounts',
            type: 'GET',
            success: function (data) {

                const labels = ['Users', 'Categories', 'Products'];
                const values = [data.users, data.categories, data.products];

                createBarChart(labels, values);
                createDoughnutChart(labels, values);
                createPolarChart(labels, values);
            }
        });
    }        function createBarChart(labels, values) {

        const ctx = document.getElementById('barChart').getContext('2d');

        if (barChartInstance) barChartInstance.destroy();

        barChartInstance = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    data: values,
                    backgroundColor: ['#0d6efd','#dc3545','#198754'],
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true } }
            }
        });
    }
        function createDoughnutChart(labels, values) {

        const ctx = document.getElementById('doughnutChart').getContext('2d');

        if (doughnutChartInstance) doughnutChartInstance.destroy();

        doughnutChartInstance = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    data: values,
                    backgroundColor: ['#0d6efd','#dc3545','#198754']
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });
    }
        function createPolarChart(labels, values) {

        const ctx = document.getElementById('polarChart').getContext('2d');

        if (polarChartInstance) polarChartInstance.destroy();

        polarChartInstance = new Chart(ctx, {
            type: 'polarArea',
            data: {
                labels: labels,
                datasets: [{
                    data: values,
                    backgroundColor: [
                        'rgba(13,110,253,0.6)',
                        'rgba(220,53,69,0.6)',
                        'rgba(25,135,84,0.6)'
                    ]
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'right'
                    }
                }
            }
        });
    }
</script>
