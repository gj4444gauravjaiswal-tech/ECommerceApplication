@{
    Layout = "_Layout1";
}

<style>
    body {
        background: #fff5f5;
    }

    .form-card {
        background: white;
        border-radius: 20px;
        padding: 35px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

        .form-card:hover {
            transform: translateY(-6px);
        }

    .form-title {
        background: linear-gradient(90deg,#8b0000,#e52d27);
        padding: 15px;
        border-radius: 12px;
        color: white;
        text-align: center;
        font-weight: 600;
        margin-bottom: 25px;
        box-shadow: 0 8px 20px rgba(229,45,39,0.3);
        letter-spacing: 1px;
    }

    .form-control {
        border-radius: 12px;
        border: 1px solid #eee;
        padding: 10px 12px;
        transition: 0.3s;
    }

        .form-control:focus {
            border-color: #e52d27;
            box-shadow: 0 0 12px rgba(229,45,39,0.3);
        }

    label {
        font-weight: 600;
        margin-bottom: 5px;
    }

    .btn-red {
        background: linear-gradient(45deg,#8b0000,#e52d27);
        border: none;
        color: white;
        font-weight: 600;
        border-radius: 12px;
        padding: 10px;
        transition: 0.3s;
        letter-spacing: 1px;
    }

        .btn-red:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 25px rgba(229,45,39,0.4);
        }
</style>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">

            <div class="form-card">

                <div class="form-title">
                    <i class="fa fa-box me-2"></i>Add Product
                </div>

                <form id="AddProd" method="post" enctype="multipart/form-data">

                    <div class="mb-3">
                        <label>Product Name</label>
                        <input type="text" id="p_name" name="p_name"
                               placeholder="Enter Product Name"
                               class="form-control shadow-sm" required />
                    </div>

                    <div class="mb-3">
                        <label>Select Category</label>
                        <select id="p_category" name="p_category"
                                class="form-control shadow-sm" required>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label>Product Description</label>
                        <input type="text" id="p_description" name="p_description"
                               placeholder="Enter Product Description"
                               class="form-control shadow-sm" required />
                    </div>

                    <div class="mb-3">
                        <label>Product Price</label>
                        <input type="number" id="p_price" name="p_price"
                               placeholder="Enter Product Price"
                               class="form-control shadow-sm" required />
                    </div>

                    <div class="mb-4">
                        <label>Product Image</label>
                        <input type="file" id="p_picture" name="p_picture"
                               class="form-control shadow-sm" required />
                    </div>

                    <button class="btn btn-red w-100" type="submit">
                        <i class="fa fa-save me-2"></i>Add Product
                    </button>

                </form>

            </div>

        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.js"></script>

<script>
    $(document).ready(function () {
        GetAllCats();

        $("#AddProd").submit(function (e) {
            e.preventDefault();

            var prodData = new FormData();
            prodData.append("P_Name", $("#p_name").val());
            prodData.append("P_Cat", $("#p_category").val());
            prodData.append("P_Desc", $("#p_description").val());
            prodData.append("P_Price", $("#p_price").val());
            prodData.append("P_Pic", $("#p_picture")[0].files[0]);

            $.ajax({
                url: '/api/APIAdmin/AddProduct',
                type: 'POST',
                data: prodData,
                contentType: false,
                processData: false,
                success: function (res) {
                    if (res != null) {
                        Swal.fire('Success!', 'Product Added Successfully', 'success');
                        $("#AddProd")[0].reset();
                    }
                    else {
                        Swal.fire('Error!', 'Something is wrong Try Again!', 'error')
                    }
                },
                error: function (err) {
                    Swal.fire('Error!', 'Server Error!', 'error');
                }
            });
        });
    });

    function GetAllCats() {
        $.ajax({
            url: "/api/APIAdmin/GetAllCategory",
            type: "GET",
            success: function (result) {

                if (result && result.length > 0) {

                    var opt = `<option value="" disabled selected>Select Category</option>`;

                    $.each(result, function (i, row) {
                        opt += `<option value="${row.c_ID}">${row.c_Name}</option>`;
                    });

                    $("#p_category").html(opt);
                }
            },
            error: function (err) {
                console.log(err);
                alert("Failed to load categories");
            }
        });
    }
</script>